# .editorconfig — configuração de encoding e indentação para editores compatíveis
# Suportado por: VS Code, PyCharm, GitPod, Cursor, e outros
# Referência: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{csv,parquet}]
# Arquivos de dados — não modificar
insert_final_newline = false
